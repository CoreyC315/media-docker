# Copy this file to .env and fill in the values:  cp .env.example .env
# The .env file is gitignored — it holds your VPN key, never commit it.

# --- User / permissions ---------------------------------------------------
# Run `id` on the VM as the user who owns the data dirs. Usually 1000:1000.
PUID=1000
PGID=1000

# Your timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/Detroit

# --- Storage --------------------------------------------------------------
# Single root that holds everything. ALL apps mount this at /data so that
# qBittorrent downloads and the Sonarr/Radarr library live on one filesystem
# (enables instant hardlinks / atomic moves instead of slow copies).
#
# Expected layout underneath DATA_ROOT:
#   data/
#     torrents/          <- qBittorrent saves here
#     media/
#       tv/              <- Sonarr library
#       movies/          <- Radarr library
#
# Can be a local path or an NFS mount you set up in /etc/fstab.
DATA_ROOT=/srv/data

# --- VPN (ProtonVPN WireGuard) --------------------------------------------
# In the Proton dashboard: Downloads -> WireGuard configuration. Create a
# config (enable NAT-PMP / port forwarding) and copy the PrivateKey line.
WIREGUARD_PRIVATE_KEY=replace-with-your-proton-wireguard-private-key

# Comma-separated country names gluetun may connect through.
VPN_SERVER_COUNTRIES=United States
